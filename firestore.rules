rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default-Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'photoURL', 'theme', 'ludoPlayed', 'ludoWon', 'updatedAt'])
        && data.keys().size() == 8
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100 && data.email == request.auth.token.email
        && data.photoURL is string && data.photoURL.size() <= 2000
        && data.theme is string && (data.theme == 'purple' || data.theme == 'pink' || data.theme == 'emerald' || data.theme == 'blue')
        && data.ludoPlayed is int && data.ludoPlayed >= 0
        && data.ludoWon is int && data.ludoWon >= 0
        && data.updatedAt == request.time;
    }

    function isValidLudoMatch(data) {
      return data.keys().hasAll(['userId', 'playerPos', 'mahiPos', 'winner', 'createdAt'])
        && data.keys().size() == 5
        && data.userId is string && data.userId == request.auth.uid
        && data.playerPos is int && data.playerPos >= 0 && data.playerPos <= 15
        && data.mahiPos is int && data.mahiPos >= 0 && data.mahiPos <= 15
        && data.winner is string && (data.winner == 'player' || data.winner == 'mahi')
        && data.createdAt == request.time;
    }

    function isValidMessageLog(data) {
      return data.keys().hasAll(['userId', 'userText', 'mahiText', 'createdAt'])
        && data.keys().size() == 4
        && data.userId is string && data.userId == request.auth.uid
        && data.userText is string && data.userText.size() <= 10000
        && data.mahiText is string && data.mahiText.size() <= 10000
        && data.createdAt == request.time;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && isEmailVerified() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
                    && isEmailVerified() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUser(incoming());

      allow update: if isSignedIn() 
                    && isEmailVerified() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'updatedAt']) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['ludoPlayed', 'updatedAt']) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['ludoPlayed', 'ludoWon', 'updatedAt'])
                    );

      allow delete: if false;

      // Subcollection: Matches
      match /matches/{matchId} {
        allow list, get: if isSignedIn() && isEmailVerified() && userId == request.auth.uid && existing().userId == request.auth.uid;
        
        allow create: if isSignedIn() 
                      && isEmailVerified() 
                      && userId == request.auth.uid
                      && isValidId(matchId)
                      && isValidLudoMatch(incoming());
                      
        allow update, delete: if false;
      }

      // Subcollection: Message Logs
      match /messages/{messageId} {
        allow list, get: if isSignedIn() && isEmailVerified() && userId == request.auth.uid && existing().userId == request.auth.uid;
        
        allow create: if isSignedIn() 
                      && isEmailVerified() 
                      && userId == request.auth.uid
                      && isValidId(messageId)
                      && isValidMessageLog(incoming());
                      
        allow update, delete: if false;
      }
    }
  }
}
